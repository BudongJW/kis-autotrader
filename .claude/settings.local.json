{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(jupyter:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "PowerShell(python*)",
      "PowerShell(pip*)",
      "PowerShell(pytest*)",
      "PowerShell(git*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Test-Path*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm:*)",
      "PowerShell(Remove-Item*)"
    ]
  }
}
