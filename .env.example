# =============================================================================
# kis-autotrader 환경변수 템플릿
# 사용법:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. 본인 값으로 채우기
#   3. .env는 절대 커밋하지 말 것 (.gitignore에 등록됨)
# =============================================================================

# -----------------------------------------------------------------------------
# 운영 모드 — paper(모의투자) 또는 live(실전)
# 처음에는 반드시 paper로 시작. 검증 전 live 금지.
# -----------------------------------------------------------------------------
MODE=paper

# -----------------------------------------------------------------------------
# KIS Developers 앱키·앱시크릿
# 발급처: https://apiportal.koreainvestment.com/intro
# 실전용과 모의투자용을 별도로 발급받아야 함
# -----------------------------------------------------------------------------

# 실전 (라이브) 계정
KIS_APPKEY=
KIS_APPSECRET=

# 모의투자 계정 (별도 발급)
KIS_VIRTUAL_APPKEY=
KIS_VIRTUAL_APPSECRET=

# -----------------------------------------------------------------------------
# 계좌 정보
# - KIS_HTSID: HTS 로그인 ID
# - KIS_ACCOUNT_NO: 계좌번호 앞 8자리 (예: 12345678)
# - KIS_ACCOUNT_PROD_CODE: 상품코드 2자리 (보통 01)
# -----------------------------------------------------------------------------
KIS_HTSID=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PROD_CODE=01

# -----------------------------------------------------------------------------
# 베이스 URL (변경 불필요, 기본값 유지)
# -----------------------------------------------------------------------------
KIS_LIVE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_URL=https://openapivts.koreainvestment.com:29443

# -----------------------------------------------------------------------------
# Rate Limit (변경 불필요, 기본값 유지)
# 실전: 초당 20건, 모의: 초당 2건 — 안전 마진 90% 적용
# -----------------------------------------------------------------------------
KIS_RATE_LIMIT_LIVE=18
KIS_RATE_LIMIT_PAPER=2

# -----------------------------------------------------------------------------
# 알림 (선택사항)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# 로깅
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
